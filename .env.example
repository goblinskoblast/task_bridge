# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=500

# AI Provider
AI_PROVIDER=openclaw
OPENCLAW_BASE_URL=http://localhost:3000
OPENCLAW_MODEL=openai/gpt-4o
OPENCLAW_TIMEOUT=60
OPENCLAW_ENFORCE_SDD_SPEC=true
OPENCLAW_SDD_SPEC_PATH=docs/sdd/specs/SPEC-OC-001-openclaw-agent.md
OPENCLAW_SDD_MAX_CHARS=24000

# DataAgent service
DATA_AGENT_URL=http://localhost:8010
DATA_AGENT_TIMEOUT=45
INTERNAL_API_URL=http://localhost:8000/api/internal/data-agent
INTERNAL_API_TOKEN=

# Supabase PostgreSQL Database Configuration
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# Example from Supabase:
# DATABASE_URL=postgresql://postgres.xxxxxxxxxxxxx:your_password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Webhook Configuration (optional)
USE_WEBHOOK=False
WEBHOOK_URL=https://your-domain.com
WEBHOOK_PATH=/webhook

# Server Configuration
HOST=0.0.0.0
PORT=8000
WEB_APP_DOMAIN=http://localhost:8000

# Logging
LOG_LEVEL=INFO
TIMEZONE=Europe/Moscow

# Email Integration (optional)
EMAIL_ENCRYPTION_KEY=your_fernet_key_here_generate_with_cryptography.fernet.Fernet.generate_key()

# Support Chat Configuration (optional)
# Telegram ID of developer to forward screenshots and critical issues
DEVELOPER_TELEGRAM_ID=your_telegram_user_id_here

# Google OAuth (Gmail one-click connect)
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.com/api/oauth/google/callback
OAUTH_STATE_SECRET=your_random_long_secret
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
YANDEX_OAUTH_REDIRECT_URI=
